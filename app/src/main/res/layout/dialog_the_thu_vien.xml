<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <EditText
        android:id="@+id/edtMaThe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Mã thẻ (tự động)"
        android:enabled="false"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Đọc giả"
        android:textSize="14sp"
        android:layout_marginBottom="4dp"/>

    <Spinner
        android:id="@+id/spnDocGia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/edtNgayCap"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ngày cấp (yyyy-MM-dd)"
        android:focusable="false"
        android:clickable="true"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/edtNgayHetHan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ngày hết hạn (yyyy-MM-dd)"
        android:focusable="false"
        android:clickable="true"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Trạng thái"
        android:textSize="14sp"
        android:layout_marginBottom="4dp"/>

    <Spinner
        android:id="@+id/spnTrangThai"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>
