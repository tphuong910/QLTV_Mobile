<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorLightBlueGray"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_dashboard"
        android:gravity="center"
        android:paddingTop="18dp"
        android:paddingBottom="22dp"
        android:text="Cập Nhật Thể Loại"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_form_card"
            android:orientation="vertical"
            android:padding="16dp">

            <EditText
                android:id="@+id/edtMaTL"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_form_input_disabled"
                android:enabled="false"
                android:hint="Mã thể loại"
                android:paddingHorizontal="12dp"
                android:textColor="@color/colorTextSecondary"
                android:textColorHint="@color/colorTextSecondary" />

            <EditText
                android:id="@+id/edtTenTL"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_form_input"
                android:hint="Tên thể loại"
                android:paddingHorizontal="12dp"
                android:textColor="@color/colorTextPrimary"
                android:textColorHint="@color/colorTextSecondary" />

            <Button
                android:id="@+id/btnSaveTheLoai"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_form_button_primary"
                android:text="Lưu cập nhật"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>