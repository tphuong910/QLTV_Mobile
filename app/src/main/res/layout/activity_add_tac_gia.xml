<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorLightBlueGray"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_dashboard"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="20dp">

        <TextView
            android:id="@+id/tvTitleTG"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Thêm Tác Giả"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/imgCloseAddTG"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@color/white" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_form_card"
                android:orientation="vertical"
                android:padding="16dp">

                <EditText
                    android:id="@+id/etMaTG"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_form_input_disabled"
                    android:enabled="false"
                    android:hint="Mã tác giả"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/colorTextSecondary"
                    android:textColorHint="@color/colorTextSecondary" />

                <EditText
                    android:id="@+id/etTenTG"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_form_input"
                    android:hint="Tên tác giả"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextSecondary" />

                <EditText
                    android:id="@+id/etNamSinhTG"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_form_input"
                    android:hint="Năm sinh"
                    android:inputType="number"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextSecondary" />

                <EditText
                    android:id="@+id/etGioiTinhTG"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_form_input"
                    android:hint="Giới tính"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextSecondary" />

                <EditText
                    android:id="@+id/etQuocTichTG"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_form_input"
                    android:hint="Quốc tịch"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextSecondary" />

                <Button
                    android:id="@+id/btnLuuTG"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_form_button_primary"
                    android:text="Lưu lại"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>