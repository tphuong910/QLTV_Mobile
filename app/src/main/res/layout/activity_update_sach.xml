<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cập Nhật Sách"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp" />

        <EditText android:id="@+id/edtTenSach" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Tên sách" android:inputType="text" android:layout_marginBottom="10dp" android:padding="10dp" android:background="#E0E0E0" />
        <EditText android:id="@+id/edtSoLuong" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Số lượng (VD: 20)" android:inputType="number" android:layout_marginBottom="10dp" android:padding="10dp" android:background="#E0E0E0" />
        <EditText android:id="@+id/edtNamXB" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Năm XB (VD: 2021)" android:inputType="number" android:layout_marginBottom="10dp" android:padding="10dp" android:background="#E0E0E0" />
        <EditText android:id="@+id/edtMaTL" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Mã Thể Loại (VD: TL006)" android:layout_marginBottom="10dp" android:padding="10dp" android:background="#E0E0E0" />
        <EditText android:id="@+id/edtMaTG" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Mã Tác Giả (VD: TG005)" android:layout_marginBottom="10dp" android:padding="10dp" android:background="#E0E0E0" />
        <EditText android:id="@+id/edtMaNXB" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Mã NXB (VD: NXB001)" android:layout_marginBottom="10dp" android:padding="10dp" android:background="#E0E0E0" />
        <EditText android:id="@+id/edtMaNN" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Mã Ngôn Ngữ (VD: NN001)" android:layout_marginBottom="10dp" android:padding="10dp" android:background="#E0E0E0" />
        <EditText android:id="@+id/edtMaViTri" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Mã Vị Trí Kệ (VD: KS001)" android:layout_marginBottom="10dp" android:padding="10dp" android:background="#E0E0E0" />

        <Button
            android:id="@+id/btnSaveSach"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lưu Lại"
            android:textSize="18sp"
            android:layout_marginTop="10dp" />

    </LinearLayout>
</ScrollView>