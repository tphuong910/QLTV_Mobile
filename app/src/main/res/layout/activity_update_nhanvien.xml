<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/imgBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:padding="5dp"
                android:src="@android:drawable/ic_menu_revert" /> <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cập Nhật Nhân Viên"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_centerInParent="true" />
        </RelativeLayout>

        <EditText
            android:id="@+id/edtMaNV"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Mã nhân viên"
            android:enabled="false"
            android:inputType="text"
            android:padding="10dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/edtTenNV"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Tên nhân viên"
            android:inputType="text"
            android:padding="10dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/edtQueQuan"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Quê quán"
            android:inputType="text"
            android:padding="10dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Giới tính"
            android:textStyle="bold"
            android:layout_marginBottom="5dp"/>
        <Spinner
            android:id="@+id/spnGioiTinh"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:entries="@array/gioi_tinh"
            android:background="#E0E0E0"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/edtNamSinh"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Năm sinh"
            android:inputType="number"
            android:padding="10dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vai trò"
            android:textStyle="bold"
            android:layout_marginBottom="5dp"/>
        <Spinner
            android:id="@+id/spnVaiTro"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:entries="@array/vai_tro"
            android:background="#E0E0E0"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/edtEmail"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Email"
            android:inputType="textEmailAddress"
            android:padding="10dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/edtSdt"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Số điện thoại"
            android:inputType="phone"
            android:padding="10dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/edtUser"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Username"
            android:inputType="text"
            android:padding="10dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/edtPass"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Password"
            android:inputType="textPassword"
            android:padding="10dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hủy"
                android:textSize="18sp"
                android:layout_marginEnd="10dp"/>

            <Button
                android:id="@+id/btnUpdate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cập Nhật"
                android:textSize="18sp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>