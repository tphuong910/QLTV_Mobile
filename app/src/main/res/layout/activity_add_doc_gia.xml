<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="HardcodedText,Autofill,TextFields"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Thêm Độc Giả Mới"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <EditText android:id="@+id/edtMaDG" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Mã Độc giả (Tự động)" android:background="#E0E0E0" android:enabled="false" android:textColor="#888888" android:padding="10dp" android:layout_marginBottom="10dp" />

        <EditText android:id="@+id/edtTenDG" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Họ và Tên Độc giả" android:background="#E0E0E0" android:padding="10dp" android:layout_marginBottom="10dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Giới tính:" android:textStyle="bold"/>
        <Spinner android:id="@+id/spnGioiTinh" android:layout_width="match_parent" android:layout_height="50dp" android:background="#E0E0E0" android:layout_marginBottom="10dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chọn Khoa:" android:textStyle="bold"/>
        <Spinner android:id="@+id/spnKhoa" android:layout_width="match_parent" android:layout_height="50dp" android:background="#E0E0E0" android:layout_marginBottom="10dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chọn Lớp:" android:textStyle="bold"/>
        <Spinner android:id="@+id/spnLop" android:layout_width="match_parent" android:layout_height="50dp" android:background="#E0E0E0" android:layout_marginBottom="10dp" />

        <EditText android:id="@+id/edtNamSinh" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Năm sinh (VD: 2004)" android:inputType="number" android:background="#E0E0E0" android:padding="10dp" android:layout_marginBottom="10dp" />

        <EditText android:id="@+id/edtDiaChi" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Địa chỉ" android:background="#E0E0E0" android:padding="10dp" android:layout_marginBottom="10dp" />

        <EditText android:id="@+id/edtEmail" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Email" android:inputType="textEmailAddress" android:background="#E0E0E0" android:padding="10dp" android:layout_marginBottom="10dp" />

        <EditText android:id="@+id/edtSoDienThoai" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Số điện thoại" android:inputType="phone" android:background="#E0E0E0" android:padding="10dp" android:layout_marginBottom="25dp" />

        <Button
            android:id="@+id/btnSaveDG"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Lưu Độc Giả"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </LinearLayout>
</ScrollView>