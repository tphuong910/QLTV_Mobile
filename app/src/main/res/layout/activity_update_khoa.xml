<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="HardcodedText,Autofill,TextFields"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cập Nhật Khoa"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="30dp" />

    <EditText
        android:id="@+id/edtMaKhoa"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Mã Khoa"
        android:padding="10dp"
        android:background="#E0E0E0"
        android:enabled="false"
        android:textColor="#888888"
        android:layout_marginBottom="15dp" />

    <EditText
        android:id="@+id/edtTenKhoa"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Tên Khoa"
        android:padding="10dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="25dp" />

    <Button
        android:id="@+id/btnUpdateKhoa"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lưu cập nhật"
        android:textSize="18sp" />

</LinearLayout>