<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorLightBlueGray"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_dashboard"
        android:gravity="center"
        android:paddingTop="18dp"
        android:paddingBottom="22dp"
        android:text="Quên Mật Khẩu"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_form_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:gravity="center"
                    android:text="Nhập thông tin để đặt lại mật khẩu"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/edtRecoverUser"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_form_input"
                    android:hint="Tên đăng nhập"
                    android:inputType="text"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextSecondary" />

                <EditText
                    android:id="@+id/edtRecoverEmail"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_form_input"
                    android:hint="Email đã đăng ký"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextSecondary" />

                <EditText
                    android:id="@+id/edtNewPassword"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_form_input"
                    android:hint="Mật khẩu mới"
                    android:inputType="textPassword"
                    android:paddingHorizontal="12dp"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextSecondary" />

                <Button
                    android:id="@+id/btnConfirmRecover"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_form_button_primary"
                    android:text="Đổi mật khẩu"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnCancelRecover"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_form_button_secondary"
                    android:text="Hủy"
                    android:textAllCaps="false"
                    android:textColor="@color/colorDeepBlue"
                    android:textStyle="bold" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</LinearLayout>