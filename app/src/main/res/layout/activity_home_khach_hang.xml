<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="#3F51B5">

            <TextView
                android:id="@+id/tvWelcomeKH"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xin chào, Khách hàng"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/imgMenuKH"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:src="@android:drawable/ic_menu_more"
                app:tint="@android:color/white" />
        </RelativeLayout>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayoutKH"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            app:tabMode="scrollable"
            app:tabSelectedTextColor="#3F51B5"
            app:tabTextColor="#757575">

            <com.google.android.material.tabs.TabItem android:text="Sách" />
            <com.google.android.material.tabs.TabItem android:text="Thể loại" />
            <com.google.android.material.tabs.TabItem android:text="Tác giả" />
            <com.google.android.material.tabs.TabItem android:text="Nhà xuất bản" />
            <com.google.android.material.tabs.TabItem android:text="Ngôn ngữ" />
            <com.google.android.material.tabs.TabItem android:text="Đang mượn" />
        </com.google.android.material.tabs.TabLayout>

        <LinearLayout
            android:id="@+id/layoutSearchKH"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Spinner
                android:id="@+id/spnFilterTheLoaiKH"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:background="@android:drawable/btn_dropdown"
                android:visibility="gone" />

            <EditText
                android:id="@+id/edtSearchKH"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_margin="16dp"
                android:background="@android:drawable/edit_text"
                android:hint="Tìm kiếm..."
                android:padding="12dp"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="8dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTitleKH"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Danh sách sách hiện có"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <ListView
            android:id="@+id/lvMainKH"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="#E0E0E0"
            android:dividerHeight="1dp" />

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabMuonSachKH"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_input_add"
        app:tint="@android:color/white"
        app:backgroundTint="#FF5722"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
